{
  "name": "mana-hyderabad",
  "version": "0.1.0",
  "description": "Multilingual civic complaint reporting platform for Hyderabad residents and municipal operations teams.",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://code.swecha.org/archishasingh/mana-hyderabad.git"
  },
  "keywords": [
    "civic-tech",
    "hyderabad",
    "fastapi",
    "nextjs",
    "postgis",
    "multilingual"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "changelog": "git-cliff --config cliff.toml -o CHANGELOG.md",
    "audit:frontend": "npm audit --audit-level=high",
    "audit:backend": "cd mana-hyderabad-backend && .venv/bin/pip-audit -r requirements.txt --no-deps --disable-pip",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "maplibre-gl": "^4.7.1",
    "next": "^15.0.3",
    "next-intl": "^3.25.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.3",
    "husky": "^9.1.7",
    "knip": "^5.44.4",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
